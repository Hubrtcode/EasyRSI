//@version=6
indicator("Easy RSI", overlay=false)

rsiLen  = input.int(14, "RSI Length", minval=1)
obLevel = input.int(70, "Overbought", minval=51, maxval=99)
osLevel = input.int(30, "Oversold",   minval=1,  maxval=49)

rsi = ta.rsi(close, rsiLen)

priceHigh  = ta.highest(high, 100)
priceLow   = ta.lowest(low, 100)
priceRange = priceHigh - priceLow
priceNorm  = priceRange != 0 ? (close - priceLow) / priceRange * 100 : 50

// colours
getColor(r) =>
    if r >= obLevel
        color.from_gradient(r, obLevel, 100, color.rgb(100, 220, 100), color.rgb(0, 255, 80))
    else if r <= osLevel
        color.from_gradient(r, 0, osLevel, color.rgb(255, 0, 0), color.rgb(255, 120, 120))
    else if r >= 50
        color.from_gradient(r, 50, obLevel, color.rgb(255, 255, 255), color.rgb(100, 220, 100))
    else
        color.from_gradient(r, osLevel, 50, color.rgb(255, 120, 120), color.rgb(255, 255, 255))

lineCol = getColor(rsi)
dist    = math.abs(rsi - 50)

// Core line 
plot(rsi, "c1", color=dist <  10               ? lineCol : na, linewidth=1)
plot(rsi, "c2", color=dist >= 10 and dist < 20 ? lineCol : na, linewidth=2)
plot(rsi, "c3", color=dist >= 20 and dist < 30 ? lineCol : na, linewidth=3)
plot(rsi, "c4", color=dist >= 30               ? lineCol : na, linewidth=4)

// Price ref
plot(priceNorm, "Price", color=color.new(#AAAAAA, 50), linewidth=1)

// Reference lines
hline(obLevel, "Overbought", color=color.new(#00C864, 70), linestyle=hline.style_dashed, linewidth=1)
hline(50,      "Mid",        color=color.new(#555555, 40), linestyle=hline.style_dotted, linewidth=1)
hline(osLevel, "Oversold",   color=color.new(#E03030, 70), linestyle=hline.style_dashed, linewidth=1)

// Labels
if ta.crossover(rsi, obLevel)
    label.new(bar_index, rsi, "Overbought ", style=label.style_label_down, color=color.new(#00C864, 20), textcolor=color.white, size=size.small)

if ta.crossunder(rsi, osLevel)
    label.new(bar_index, rsi, "Oversold", style=label.style_label_up, color=color.new(#E03030, 20), textcolor=color.white, size=size.small)

// scale
var table scale = table.new(position.middle_right, 3, 5, border_width=0)

if barstate.islast
    table.cell(scale, 0, 0, "100", text_color=#555555, text_size=size.small, text_halign=text.align_right, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 0, 1, str.tostring(obLevel), text_color=#00C864, text_size=size.small, text_halign=text.align_right, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 0, 2, "50",  text_color=#555555, text_size=size.small, text_halign=text.align_right, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 0, 3, str.tostring(osLevel), text_color=#E03030, text_size=size.small, text_halign=text.align_right, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 0, 4, "0",   text_color=#555555, text_size=size.small, text_halign=text.align_right, bgcolor=color.rgb(0,0,0,0))

    table.cell(scale, 1, 0, " | ", text_color=#333333, text_size=size.small, text_halign=text.align_center, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 1, 1, " | ", text_color=#333333, text_size=size.small, text_halign=text.align_center, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 1, 2, " | ", text_color=#333333, text_size=size.small, text_halign=text.align_center, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 1, 3, " | ", text_color=#333333, text_size=size.small, text_halign=text.align_center, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 1, 4, " | ", text_color=#333333, text_size=size.small, text_halign=text.align_center, bgcolor=color.rgb(0,0,0,0))

    table.cell(scale, 2, 0, str.tostring(math.round(priceHigh)),                             text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 2, 1, str.tostring(math.round(priceLow + priceRange * (obLevel/100))), text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 2, 2, str.tostring(math.round(priceLow + priceRange * 0.5)),           text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 2, 3, str.tostring(math.round(priceLow + priceRange * (osLevel/100))), text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left, bgcolor=color.rgb(0,0,0,0))
    table.cell(scale, 2, 4, str.tostring(math.round(priceLow)),                              text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left, bgcolor=color.rgb(0,0,0,0))
